#!/usr/bin/env bash
# codetour.nvim pre-commit hook
#
# Runs stylua --check + the plenary spec suite if any Lua files are staged.
# Doc-only commits (README, etc.) skip the check entirely.
#
# Install via:  make hooks
# Bypass via:   git commit --no-verify   (use sparingly)

set -euo pipefail

if git diff --cached --name-only --diff-filter=ACM | grep -qE '\.lua$'; then
  echo "==> stylua --check"
  make check

  echo "==> make test"
  make test
fi
